# ═══════════════════════════════════════════════════════════════
#  Bounties & Berries – Backend Environment Configuration
#  Copy this file to .env and fill in real values.
#  NEVER commit .env to source control.
# ═══════════════════════════════════════════════════════════════

# ─── Server ────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development          # development | production | test

# ─── CORS ──────────────────────────────────────────────────────
# In production: set to the actual frontend origin, e.g. https://app.yoursite.com
FRONTEND_URL=http://localhost:8081

# ─── Database (PostgreSQL) ─────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bnb_db
DB_USER=postgres
DB_PASSWORD=your_strong_password_here   # REQUIRED – change this!

# ─── Authentication ────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret  # REQUIRED – change this!
JWT_EXPIRES_IN=7d

# ─── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_MAX=100              # max requests per IP per 15-minute window
                                # Increase temporarily for load testing

# ─── File Uploads ──────────────────────────────────────────────
# Local upload directory (relative to server root)
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5

# ─── Logging ───────────────────────────────────────────────────
LOG_LEVEL=info                  # error | warn | info | debug

# ─── Sentry (optional – error monitoring) ─────────────────────
# ─── GitHub OAuth (for connecting accounts) ─────────────────────
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:3001/api/auth/github/callback
